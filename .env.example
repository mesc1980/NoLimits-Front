# ============================================================
# no/limits — Variables de entorno
# Copia como .env y completá los valores.
# NUNCA comitees .env con claves reales.
# ============================================================

# TMDB — Películas, series, watch providers
# Obtener en: https://www.themoviedb.org/settings/api
VITE_TMDB_KEY=tu_tmdb_api_key

# IGDB (Twitch) — Video games database
# IMPORTANTE: El client_secret NO va acá. Solo el access_token generado.
# Obtener credenciales en: https://dev.twitch.tv/console/apps
# Generar token (válido ~60 días):
#   curl -X POST "https://id.twitch.tv/oauth2/token" \
#     -d "client_id=TU_CLIENT_ID&client_secret=TU_SECRET&grant_type=client_credentials"
VITE_IGDB_CLIENT_ID=tu_client_id_de_twitch
VITE_IGDB_TOKEN=tu_access_token_generado

# Backend propio (descomentar cuando exista)
# Con el backend, IGDB_TOKEN se renueva automáticamente server-side.
# VITE_API_BASE_URL=https://api.nolimits.app
# VITE_API_BASE_URL=http://localhost:3000
